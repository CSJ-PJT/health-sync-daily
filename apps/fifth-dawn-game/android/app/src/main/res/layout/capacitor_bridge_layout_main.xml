<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fd_background"
    tools:context=".MainActivity">

    <com.getcapacitor.CapacitorWebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/fd_background" />

    <LinearLayout
        android:id="@+id/native_debug_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#AA07111F"
        android:elevation="16dp"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/native_debug_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deep Stake Android shell is alive"
            android:textColor="#E2F7E2"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/native_debug_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="If this text appears, the native layout rendered successfully."
            android:textColor="#D7E6F3"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
