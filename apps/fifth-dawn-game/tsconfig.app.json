{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "noFallthroughCasesInSwitch": false,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@health-sync/shared-auth": ["../../packages/shared-auth/src/index.ts"],
      "@health-sync/shared-profile": ["../../packages/shared-profile/src/index.ts"],
      "@health-sync/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@health-sync/game-link-sdk": ["../../packages/game-link-sdk/src/index.ts"],
      "@health-sync/design-system": ["../../packages/design-system/src/index.ts"]
    }
  },
  "include": ["src"]
}
