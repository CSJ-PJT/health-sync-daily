+        private static void CreateGroundArtPiece(Transform parent, GroundArtZoneSpec spec, FirstScreenGroundArtConfig config)
+        {
+            var actualPrimitive = spec.PrimitiveType == PrimitiveType.Cube ? PrimitiveType.Cube : PrimitiveType.Cube;
+            var actualScale = actualPrimitive == PrimitiveType.Cube
+                ? spec.LocalScale
+                : ConvertGroundArtScale(spec.PrimitiveType, spec.LocalScale);
+            var piece = CreateVisualPiece(
+                parent,
+                actualPrimitive,
+                spec.Name,
+                spec.LocalPosition + new Vector3(0f, spec.YOffset, 0f),
+                actualScale,
+                GetGroundArtMaterial(spec.Surface, config));
+            if (spec.PrimitiveType != PrimitiveType.Cube)
+            {
+                piece.transform.localRotation = Quaternion.Euler(0f, GetGroundPieceYaw(spec.Name, spec.Group), 0f);
+            }
+            StabilizeGroundRenderer(piece);
+        }
