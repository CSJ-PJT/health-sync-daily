+        public static void RefreshFirstScreenGroundArt(Transform zoneRoot, WorldPrototype3DDefinition definition)
+        {
+            if (zoneRoot == null)
+            {
+                return;
+            }
+
+            var generatedRoot = zoneRoot.Find(GeneratedVisualRootName);
+            if (generatedRoot == null)
+            {
+                var generatedObject = new GameObject(GeneratedVisualRootName);
+                generatedObject.transform.SetParent(zoneRoot, false);
+                generatedRoot = generatedObject.transform;
+            }
+
+            GenerateFirstScreenGroundArt(generatedRoot, definition);
+        }
+
+        public static void ClearFirstScreenGroundArt(Transform zoneRoot)
+        {
+            if (zoneRoot == null)
+            {
+                return;
+            }
+
+            var generatedRoot = zoneRoot.Find(GeneratedVisualRootName);
+            if (generatedRoot == null)
+            {
+                return;
+            }
+
+            var groundRoot = generatedRoot.Find(GeneratedGroundArtRootName);
+            if (groundRoot == null)
+            {
+                return;
+            }
+
+            if (Application.isPlaying)
+            {
+                Object.Destroy(groundRoot.gameObject);
+            }
+            else
+            {
+                Object.DestroyImmediate(groundRoot.gameObject);
+            }
+        }
