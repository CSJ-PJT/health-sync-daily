+        private static Transform EnsureGroundArtRoot(Transform root)
+        {
+            var groundRoot = root.Find(GeneratedGroundArtRootName);
+            if (groundRoot != null)
+            {
+                return groundRoot;
+            }
+
+            var groundObject = new GameObject(GeneratedGroundArtRootName);
+            groundObject.transform.SetParent(root, false);
+            return groundObject.transform;
+        }
