+        private static Vector3 ConvertGroundArtScale(PrimitiveType primitiveType, Vector3 scale)
+        {
+            if (primitiveType == PrimitiveType.Cylinder || primitiveType == PrimitiveType.Capsule || primitiveType == PrimitiveType.Sphere)
+            {
+                return new Vector3(scale.x * 0.5f, scale.y, scale.z * 0.5f);
+            }
+
+            return scale;
+        }
