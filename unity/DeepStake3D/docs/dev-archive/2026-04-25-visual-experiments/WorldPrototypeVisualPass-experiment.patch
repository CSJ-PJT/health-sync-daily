+        private static float GetGroundPieceYaw(string label, GroundArtGroup group)
+        {
+            if (group == GroundArtGroup.BaseTerrain)
+            {
+                return 0f;
+            }
+
+            var hash = Mathf.Abs(label.GetHashCode());
+            var bucket = hash % 5;
+            return bucket switch
+            {
+                0 => -10f,
+                1 => -5f,
+                2 => 0f,
+                3 => 5f,
+                _ => 10f
+            };
+        }
